APP_NAME="InteTeam Garage"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

PORT=8085
PHPMYADMIN_PORT=8086

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=inteteam_garage
DB_USERNAME=garage
DB_PASSWORD=GaragePass2026!
DB_ROOT_PASSWORD=GarageRoot2026!

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=GarageRedis2026!
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="garage@inte.team"
MAIL_FROM_NAME="${APP_NAME}"

# Google Cloud Storage
GCS_PROJECT_ID=
GCS_KEY_FILE_PATH=
GCS_BUCKET=
GCS_SIGNED_URL_EXPIRY_MINUTES=30

# InteTeam CRM API
CRM_API_URL=
CRM_API_SECRET=

# SSO (mechanic dashboard)
SSO_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# SSO (customer account portal — separate OAuth2 client, redirect_uri = /account/callback)
SSO_CUSTOMER_CLIENT_ID=
SSO_CUSTOMER_CLIENT_SECRET=

# DVLA Vehicle Enquiry Service (MOT + Road Tax expiry lookup)
# Register at: https://register-for-the-vehicle-enquiry-service-vehicle-checker-api.service.gov.uk/
DVLA_VES_URL=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles
DVLA_VES_API_KEY=
DVLA_VES_TIMEOUT=10

# LLM Translation
OPENAI_API_KEY=
TRANSLATION_MODEL=gpt-4o-mini

VITE_APP_NAME="${APP_NAME}"
